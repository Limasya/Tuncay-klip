# ─── Klip Sakso Patso — Environment Configuration ───
# Copy this file to .env and fill in your values.

# ─── Kick API ────────────────────────────────────────
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
KICK_REDIRECT_URI=http://localhost:8000/auth/callback
KICK_BROADCASTER_USER_ID=
# This deployment only analyses the public data of this fixed channel.
KICK_CHANNEL_SLUG=thetuncay

# ─── Stream Settings ─────────────────────────────────
STREAM_BUFFER_SECONDS=30
CLIP_PRE_SECONDS=5
CLIP_POST_SECONDS=5
ANALYSIS_FPS=2
MAX_CLIP_DURATION=60

# ─── Redis ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Database ────────────────────────────────────────
# Dev (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./data/klip.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/klip_db

# ─── AWS S3 (for clip storage) ──────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
S3_BUCKET_NAME=klip-storage

# ─── Whisper (speech-to-text) ───────────────────────
# Options: tiny, base, small, medium, large
WHISPER_MODEL_SIZE=base

# ─── Emotion Detection ──────────────────────────────
EMOTION_THRESHOLD=0.7
EXCITEMENT_THRESHOLD=0.8

# ─── Security ────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-random-64-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Kimlik doğrulamayı kapatır (SADECE dev/test). production'da True olursa uygulama açılmaz.
AUTH_DISABLED=false
# Admin API key for dashboard and programmatic access.
# Startup'ta bu key otomatik olarak default_api_key_store'a kaydedilir.
# Dashboard'daki "API Key" inputuna yapıştırarak kullanın.
# Boş bırakırsanız dashboard sadece WS ile çalışır (polling 401 döner).
ADMIN_API_KEY=

# ─── CORS ────────────────────────────────────────────
# Virgülle ayrılmış izinli origin listesi. Prod'da gerçek domain(ler)i yazın.
# Prod'da '*' yasaktır ve localhost varsayılanı kalırsa uyarı loglanır.
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CORS_ALLOW_CREDENTIALS=false

# ─── Server ──────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── Webhook Notifications ──────────────────────────
# Discord webhook URL (format: https://discord.com/api/webhooks/...)
DISCORD_WEBHOOK_URL=
# Telegram bot token + chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Generic webhook URL (any HTTP endpoint)
GENERIC_WEBHOOK_URL=
# HMAC secret for webhook signature verification
WEBHOOK_SECRET=
# Max notifications per minute
WEBHOOK_RATE_LIMIT=30

# ─── Logging ─────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Set to "json" for structured JSON logging (production)
LOG_FORMAT=

# ─── Rate Limiting ─────────────────────────────────────
# Enable rate limiting (true/false)
RATE_LIMIT_ENABLED=false
# Max requests per window
RATE_LIMIT_MAX=200
# Window size in seconds
RATE_LIMIT_WINDOW=60

# ─── LLM Providers (tried in order, first available wins) ──

# Cloud providers (set API key to enable)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-haiku-20240307

GEMINI_API_KEY=                  # Free: 15 RPM, 1M tokens/day (https://aistudio.google.com/apikey)
GEMINI_MODEL=gemini-2.5-flash

MISTRAL_API_KEY=                 # Free tier available (https://console.mistral.ai/)
MISTRAL_MODEL=mistral-small-latest

GROQ_API_KEY=                    # Free, ultra-fast (https://console.groq.com)
GROQ_MODEL=llama-3.3-70b-versatile

COHERE_API_KEY=                  # Free tier (https://dashboard.cohere.com)
COHERE_MODEL=command-r

TOGETHER_API_KEY=                # Free $25 credit (https://api.together.xyz)
TOGETHER_MODEL=meta-llama/Llama-3.1-70B-Instruct-Turbo

CEREBRAS_API_KEY=                # Free wafer-scale fast (https://cloud.cerebras.ai)
CEREBRAS_MODEL=llama3.1-70b

OPENROUTER_API_KEY=              # Free models available (https://openrouter.ai)
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Local inference (set host URL to enable)
OLLAMA_HOST=                     # e.g. http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

VLLM_HOST=                       # e.g. http://localhost:8000 (OpenAI-compatible)
VLLM_MODEL=meta-llama/Llama-3-8B-Instruct

LM_STUDIO_HOST=                  # e.g. http://localhost:1234 (OpenAI-compatible)
LM_STUDIO_MODEL=default

LOCALAI_HOST=                    # e.g. http://localhost:8080 (OpenAI-compatible)
LOCALAI_MODEL=gpt-3.5-turbo

TEXTGEN_HOST=                    # e.g. http://localhost:5000 (oobabooga, OpenAI-compatible)
TEXTGEN_MODEL=default

HUGGINGFACE_API_TOKEN=           # Free: 1000 req/day (https://huggingface.co/settings/tokens)
HUGGINGFACE_MODEL=HuggingFaceH4/zephyr-7b-beta

# ─── LiteLLM SDK (zero-cost multi-provider router) ─────────────────
# LiteLLM facade uses litellm_config.yaml for provider chain config.
# Set LITELLM_SMOKE_REAL=1 to enable real API tests (needs provider keys above).
LITELLM_SMOKE_REAL=

# ─── Stock Video (Pexels + Pixabay — free) ────────────────────────
PEXELS_API_KEY=                  # Free: 200 req/h (https://www.pexels.com/api/)
PIXABAY_API_KEY=                 # Free: unlimited (https://pixabay.com/api/docs/)

# ─── Social Media Posting (Postiz self-hosted) ─────────────────────
# Postiz: open-source social media scheduler (AGPL-3.0, self-hosted, $0).
# Setup: docker compose -f docker-compose.postiz.yml up -d
# Or point to existing Postiz instance.
POSTIZ_URL=http://localhost:5000
POSTIZ_API_KEY=

# ─── Observability ─────────────────────────────────────
DEPLOYMENT_ENVIRONMENT=development
OTEL_ENABLED=false
PROMETHEUS_METRICS_ENABLED=true

# ─── Public Kick Archive: kick.com/thetuncay only ───────
# Starts a periodic discovery job after API startup. The service records
# completed VOD IDs in data/kick_archive_state.json and does not reprocess them.
KICK_ARCHIVE_AUTOSTART=true
KICK_ARCHIVE_VOD_LIMIT=3
KICK_ARCHIVE_MAX_CLIPS_PER_VOD=5
KICK_ARCHIVE_INTERVAL_MINUTES=360
KICK_ARCHIVE_STATE_FILE=data/kick_archive_state.json

# ─── Docker Compose Secrets (production) ────────────────
# docker-compose.yml bu değerleri ${VAR} ile okur — düz metin secret yok.
# POSTGRES_PASSWORD ve GRAFANA_ADMIN_PASSWORD set edilmezse compose başlamaz.
POSTGRES_DB=klip
POSTGRES_USER=klip
POSTGRES_PASSWORD=change-me-strong-db-password
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-strong-grafana-password

# ─── Postiz (opsiyonel sosyal medya publiser) ────────────
# docker-compose.postiz.yml bu değerleri referans alır.
# POSTIZ_JWT_SECRET zorunludur — set edilmezse compose başlamaz.
POSTIZ_URL=http://localhost:5000
POSTIZ_API_KEY=
POSTIZ_JWT_SECRET=change-me-strong-postiz-jwt-secret
POSTIZ_DB_NAME=postiz
POSTIZ_DB_USER=postiz
POSTIZ_DB_PASSWORD=change-me-strong-postiz-db-password
