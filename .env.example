# Kick API
KICK_CLIENT_ID=your_kick_client_id
KICK_CLIENT_SECRET=your_kick_client_secret
KICK_REDIRECT_URI=http://localhost:8000/auth/callback
KICK_BROADCASTER_USER_ID=target_broadcaster_id
KICK_CHANNEL_SLUG=target_channel_slug

# Stream Settings
STREAM_BUFFER_SECONDS=30
CLIP_PRE_SECONDS=5
CLIP_POST_SECONDS=5
ANALYSIS_FPS=2
MAX_CLIP_DURATION=60

# Redis
REDIS_URL=redis://redis:6379/0

# Database
DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/klip_db

# AWS / S3
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=eu-central-1
S3_BUCKET_NAME=klip-storage

# Whisper
WHISPER_MODEL_SIZE=base

# Emotion Analysis
EMOTION_THRESHOLD=0.7
EXCITEMENT_THRESHOLD=0.8

# Security
SECRET_KEY=your_jwt_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Server
HOST=0.0.0.0
PORT=8000
